<?xml version="1.0" encoding="UTF-8" ?>
<ruleset name="PHP Katas">
    <description>Code style rules for PHP Kata practice</description>

    <rule ref="PSR12" />
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
        </properties>
    </rule>

    <arg name="extensions" value="php" />

    <arg value="sp" />
    <arg name="colors" />

    <file>./src</file>
    <file>./tests</file>
    <exclude-pattern>vendor/*</exclude-pattern>
</ruleset>